{
  "version": 2,
  "functions": {
    "api/gemini.js": {
      "maxDuration": 30
    },
    "api/news.js": {
      "maxDuration": 10
    }
  },
  "routes": [
    { "src": "/api/news",   "dest": "/api/news.js" },
    { "src": "/api/gemini", "dest": "/api/gemini.js" },
    { "src": "/(.*)",       "dest": "/index.html" }
  ]
}
